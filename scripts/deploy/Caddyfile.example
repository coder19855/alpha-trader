# OPTIONAL — only when using Caddy for HTTPS on trading-bot.in.
# Default VPS setup uses provider port map :20063 → :3000 (no Caddy).
# See scripts/deploy/setup-direct-access.sh
#
# Until trading-bot.in DNS points at this VPS, use :80 so the IP works:
:80 {
    reverse_proxy 127.0.0.1:3000
}

# After DNS is live, replace with:
# trading-bot.in, www.trading-bot.in {
#     reverse_proxy 127.0.0.1:3000
# }
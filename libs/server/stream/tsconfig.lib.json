{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": false,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "../shared/src/lib/types/fyers-api-v3.d.ts"
  ],
  "references": [
    {
      "path": "../position/tsconfig.lib.json"
    },
    {
      "path": "../market-data/tsconfig.lib.json"
    },
    {
      "path": "../analysis/tsconfig.lib.json"
    },
    {
      "path": "../shared/tsconfig.lib.json"
    }
  ],
  "exclude": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}